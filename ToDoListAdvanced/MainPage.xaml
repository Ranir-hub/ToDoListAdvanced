<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoListAdvanced.MainPage">

    <Grid RowDefinitions="*,60" Padding="10" ColumnSpacing="10">
        <ScrollView>
            <VerticalStackLayout Grid.Row="0" Padding ="20,0" Spacing="10" >
                <Grid ColumnDefinitions="*,242,45" ColumnSpacing="10">
                    <Entry Grid.Column="0" Placeholder="Введите задачу" Text="{Binding NewTaskTitle}"/>
                    <TimePicker Grid.Column="1" Time="{Binding NewTaskDeadline}" Format="HH:mm"/>
                    <Button Grid.Column="2" Text="+" Command="{Binding Add}" TextColor="Black"/>
                </Grid>

                <CollectionView x:Name="ToDoListViewModel" ItemsSource="{Binding CurrentTasks}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="30, 26, *, 242, 45" Padding="10, 4" ColumnSpacing="10">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                
                                <Label Grid.Column="0" Text="=" FontSize="18" VerticalOptions="Center" HorizontalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <DragGestureRecognizer 
                                            CanDrag="True"
                                            DragStartingCommand="{Binding Source={x:Reference Name=ToDoListViewModel}, Path=BindingContext.DragStartingCommand}" 
                                            DragStartingCommandParameter="{Binding}" />
                                    </Label.GestureRecognizers>
                                </Label>

                                <CheckBox Grid.Column="1" IsChecked="{Binding Complete, Mode=TwoWay}"/>
                                <Entry Grid.Column="2" Text="{Binding Title, Mode=TwoWay}" FontSize="16"/>
                                <TimePicker Grid.Column="3" Time="{Binding Deadline}" Format="HH:mm"/>
                                <Button Grid.Column="4" Text="-" Command="{Binding Source={x:Reference Name=ToDoListViewModel}, Path=BindingContext.Remove}" CommandParameter="{Binding}" TextColor="Black"/>

                                <Grid.GestureRecognizers>
                                    <DropGestureRecognizer 
                                        AllowDrop="True"
                                        DropCommand="{Binding Source={x:Reference Name=ToDoListViewModel}, Path=BindingContext.DropCommand}" 
                                        DropCommandParameter="{Binding}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <HorizontalStackLayout Grid.Row="1" Spacing="10" HorizontalOptions="Center">
            <DatePicker Date="{Binding CurrentDay}"/>
        </HorizontalStackLayout>
    </Grid>

</ContentPage>
