<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoListAdvanced.MainPage">

    <Grid RowDefinitions="*,110" Padding="30,10" ColumnSpacing="10">
        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="10" >

            <Grid ColumnDefinitions="*,50" ColumnSpacing="10">
                <Entry Grid.Column="0" 
                       Placeholder="Enter task" Text="{Binding Task}" 
                       HorizontalOptions="Fill"/>
                <Button Grid.Column="1" Text="+" 
                        HorizontalOptions="End" WidthRequest="40"/>
            </Grid>

            <CollectionView ItemsSource="{Binding ToDoList}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <StackLayout>
                            <Entry Text="{Binding Title}"/>
                            <Editor Text="{Binding Description}"/>
                            <CheckBox IsChecked="{Binding Complete}"/>
                        </StackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <HorizontalStackLayout Grid.Row="1" Spacing="10" HorizontalOptions="Center">
            <Button ImageSource="list.png"
                    MaximumWidthRequest="110" 
                    MinimumWidthRequest="50"></Button>
            <Button ImageSource="calendar.png"
                    MaximumWidthRequest="110"
                    MinimumWidthRequest="50"></Button>
        </HorizontalStackLayout>
    </Grid>

</ContentPage>
